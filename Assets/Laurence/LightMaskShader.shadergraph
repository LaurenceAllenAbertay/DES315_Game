{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "4101787d0a4840cb943aa4338bc9c720",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetLightData (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -670.9999389648438,
            "y": 245.99996948242188,
            "width": 229.99996948242188,
            "height": 94.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "4da60f2dfde24ca3af7cc11429264e68"
        },
        {
            "m_Id": "f6a5924b6f7546ce8660c203300ead56"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetLightData",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if defined(UNIVERSAL_LIGHTING_INCLUDED)\n    float3 positionWS = WorldPos;\n    float4 shadowCoord = TransformWorldToShadowCoord(positionWS);\n    \n    // Initialize with 0\n    float finalAtten = 0;\n\n    // Check Main Light (if any)\n    Light mainLight = GetMainLight(shadowCoord);\n    finalAtten += mainLight.distanceAttenuation * mainLight.shadowAttenuation;\n\n    // Loop through Torches (Additional Lights)\n    int pixelLightCount = GetAdditionalLightsCount();\n    for (int i = 0; i < pixelLightCount; ++i)\n    {\n        // This specific overload is required to get shadows for additional lights\n        Light addLight = GetAdditionalLight(i, positionWS, shadowCoord);\n        finalAtten += addLight.distanceAttenuation * addLight.shadowAttenuation;\n    }\n    Attenuation = finalAtten;\n#else\n    Attenuation = 1.0;\n#endif"
}

